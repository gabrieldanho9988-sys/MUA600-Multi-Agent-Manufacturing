                              [
                                "PostAction",
                                {
                                  "Name": "PostAction",
                                  "ClassName": "cmas.ontology.processplan.ProcessPlan",
                                  "Description": "An action to be execute after the process plan is done.",
                                  "CanInherit": true,
                                  "Override": true,
                                  "ReadOnly": false,
                                  "ParentID": "",
                                  "PropertyType": "[INHERITANCE]",
                                  "LocalValue": "NONE"
                                }
                              ],
                              [
                                "TargetType",
                                {
                                  "Name": "TargetType",
                                  "ClassName": "cmas.ontology.processplan.ProcessPlan",
                                  "Description": "A target type of the process plan.",
                                  "CanInherit": true,
                                  "Override": true,
                                  "ReadOnly": false,
                                  "ParentID": "",
                                  "PropertyType": "[STRINGEDIT, MODELLING]",
                                  "LocalValue": ""
                                }
                              ],
                              [
                                "Actions",
                                {
                                  "Name": "Actions",
                                  "ClassName": "cmas.ontology.processplan.ProcessPlanStructuredText",
                                  "Description": "Process plan actions",
                                  "CanInherit": true,
                                  "Override": true,
                                  "ReadOnly": false,
                                  "ParentID": "",
                                  "PropertyType": "[TEXTEDITOR]",
                                  "LocalValue": "Program Process1Run;\n\nvar state:\u003d0: integer;\n\nprocedure changeState(newState:integer);\nbegin\n\tif newState\u003c\u003estate then begin\n\t\tstate:\u003dnewState;\n\tend;\nend.\n\nfunction onRun() : integer;\nbegin\n\tonRun:\u003dprocessplan.running;\n\tsleep(50);\n\n\tcase state of\n\t0:\n\t\twriteln(\u0027Start to run \u0027 + agent.name);\n\t\tinterface.runFailed:\u003dfalse;\n\t\tchangeState(10);\n\n\t10:  // Check that it is ok to run\n\t        \n\t\tif agent.failed then begin\n\t\t\tinterface.runFailed:\u003dtrue;\n\t\t\tchangeState(60);\n\t\tend;\n\t\telse if agent.sensor and not agent.isRunning then\n\t\t\tchangeState(20);\n\t\telse\n\t\t\terror \u0027process not ready missing a part\u0027;\n\t\tagent.run:\u003dfalse;\n\n\t20:  // Start process\n\t\tagent.run:\u003dtrue;\n\t\tchangeState(30);\n\n\t30:  // Wait for feedback that the process is running\n\t\tif agent.failed then begin\n\t\t\tagent.run:\u003dfalse;\n\t\t\tinterface.runFailed:\u003dtrue;\n\t\t\tchangeState(60);\n\t\tend;\n\t\telse if agent.isRunning then changeState(40);\n\n\t40:  // Wait until process is done\n\t\tagent.run:\u003dfalse;\n\t\tif agent.failed then begin\n\t\t\tinterface.runFailed:\u003dtrue;\n\t\t\tchangeState(60);\n\t\tend;\n\t\telse if not agent.isRunning then changeState(50);\n\n\t50:  // We are done\n\t\tchangeState(0);\n\t\tonRun:\u003dprocessplan.done;\n\n\t60:  // R4: failed — return cleanly, runFailed is set\n\t\tchangeState(0);\n\t\tonRun:\u003dprocessplan.done;\n\n\telse:\n\t\terror \u0027wrong state: \u0027 + inttostring(state);\n\tend;\nend."
                                }
                              ]
                            ],
