                                }
                              ],
                              [
                                "Cost",
                                {
                                  "Name": "Cost",
                                  "ClassName": "cmas.ontology.processplan.ProcessPlan",
                                  "Description": "The cost to execute the process plan, can be used for optimisation.",
                                  "CanInherit": true,
                                  "Override": true,
                                  "ReadOnly": false,
