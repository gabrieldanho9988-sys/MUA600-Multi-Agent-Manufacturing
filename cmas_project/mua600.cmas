                  [
                    "Actions",
                    {
                      "Name": "Actions",
                      "ClassName": "cmas.ontology.agents.AgentAction",
                      "Description": "User defined actions",
                      "CanInherit": true,
                      "Override": true,
                      "ReadOnly": false,
                      "ParentID": "",
                      "PropertyType": "[TEXTEDITOR, MODELLING]",
                      "LocalValue": "program CraneMain;\n\nvar oldx:\u003d-1, oldy:\u003d-1:integer;\n\n// Main controller for the crane motion\nprocedure running;\nbegin\n\tif oldx\u003c\u003eagent.targetX then begin\n\t\tagent.setX:\u003dagent.targetX;\n\t\toldx:\u003dagent.targetX;\n\tend;\n\n\tif oldy\u003c\u003eagent.targetY then begin\n\t\tagent.setY:\u003dagent.targetY;\n\t\toldy:\u003dagent.targetY;\n\tend;\nend.\n\n// Constructor\nbegin\n\tagent.targetX:\u003dagent.posX;\n\tagent.targetY:\u003dagent.posY;\n\t\n\toldx:\u003dagent.targetX;\n\toldy:\u003dagent.targetY;\t\nend."
                    }
                  ],
