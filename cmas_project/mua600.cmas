                  [
                    "Actions",
                    {
                      "Name": "Actions",
                      "ClassName": "cmas.ontology.processplan.ProcessPlanStructuredText",
                      "Description": "Process plan actions",
                      "CanInherit": true,
                      "Override": true,
                      "ReadOnly": false,
                      "ParentID": "",
                      "PropertyType": "[TEXTEDITOR]",
                      "LocalValue": "\n// Common constants\nvar constant SAFE_HEIGHT:\u003d150 : integer;\n\n// Common functions for crane\n\nfunction isMowing(): boolean;\nbegin\n\tisMowing:\u003dNOT (agent.targetX\u003dagent.posX AND agent.targetY\u003dagent.posY);\nend.\n\nfunction isAtPosition(x,y:integer): boolean;\nbegin\n\tisAtPosition:\u003d x\u003dagent.posX AND y\u003dagent.posY;\nend.\n\nfunction isAtTarget(): boolean;\nbegin\n\tisAtTarget:\u003d agent.targetX\u003dagent.posX AND agent.targetY\u003dagent.posY;\nend.\n\n"
                    }
                  ]
