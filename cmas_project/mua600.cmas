                "ParentID": "",
                "PropertyType": "[STRINGEDIT, MODELLING]",
                "LocalValue": ""
              }
            ],
            [
              "Actions",
              {
                "Name": "Actions",
                "ClassName": "cmas.ontology.processplan.ProcessPlanStructuredText",
                "Description": "Process plan actions",
                "CanInherit": true,
                "Override": true,
                "ReadOnly": false,
                "ParentID": "",
                "PropertyType": "[TEXTEDITOR]",
                "LocalValue": "Program Processplan_Process2;\n// ── R1: abstract interfaces — the crane only ever sees coordinates,\n//        never the part type or process identity\nstruct tPosition;\nbegin\n\tvar x1, y1, x2, y2 : integer;\nend;\n\ndefine transport : interface;   // R1: crane\u0027s interface — position only\nbegin\n\tvar position : tPosition;\nend;\n\ndefine ProcessInterface : interface;   // R2: has a \"process\" field — set to 2\nbegin                                  //     to request type-2 processing\n\tvar x, y : integer;\n\tvar process : integer;\n\tvar runFailed : boolean;       // R4: flag the process sets if it fails\nend;\n\ndefine sink : interface;               // R1: sink is abstract too — coordinates only\nbegin\n\tvar x, y : integer;\nend;\n\nvar savedX:\u003d0 : integer;               // R4: remembers failed-process location\nvar savedY:\u003d0 : integer;               //     so the crane can pick up from there\n\nfunction onRun() : integer;\nbegin\n\twriteln(\u0027Start process plan for process 2\u0027);\n\n\t// Book a process and bring part to it\n\tthreadmessage(\u0027book a process\u0027);\n\t// ── R2: THIS single line is what makes this a type-2 part.\n    //        RunProcess1 has process:\u003d1. That is the only difference.\n    //        Crane, Sources, Sink are completely unchanged.\n\tProcessInterface.process:\u003d2;  \n// ── R1: decentralised discovery — the Part finds a free process by itself.\n    //        No coordinator tells it which one. CMAS broadcasts and picks. \n\tProcessInterface.agreeandbook();\n\n\tthreadmessage(\u0027get process xy\u0027);\n\t// ── R3: runtime location — the Part asks the booked process \"where are you?\"\n    //        The coordinate is not hardcoded anywhere in this file.\n\tProcessInterface.getXY();\n\n\tthreadmessage(\u0027ask a transporter to move to process\u0027);\n\t// ── R1: the crane receives only X/Y numbers. It does not know\n    //        it is carrying a type-2 part or that it is going to Process2.\n\ttransport.position.x1:\u003dagent.x;\n\ttransport.position.y1:\u003dagent.y;\n\ttransport.position.x2:\u003dProcessInterface.x;\n\ttransport.position.y2:\u003dProcessInterface.y;\n\ttransport.agreeandbook();\n\ttransport.PickAndPlace();\n\ttransport._unbook();\n\n\t// Run the process\n\tthreadmessage(\u0027run process\u0027);\n\t// ── R1: Part tells Process to run its operation. Decentralised command.\n\tProcessInterface.run();\n\n\t// R4: if the process failed, find and use an alternative\n\t// R4: FAILURE RECOVERY BLOCK\n    // If Process2 failed, find an alternative and try again.\n\tif ProcessInterface.runFailed then begin\n\t\twriteln(\u0027Process failed — searching for an alternative\u0027);\n\t\tsavedX:\u003dProcessInterface.x;   // R4: save failed location\n\t\tsavedY:\u003dProcessInterface.y;   // R4: release the failed process\n\n\t\tProcessInterface._unbook();\n\n\t\tthreadmessage(\u0027re-booking an alternative process\u0027);\n\t\t// R4 + R1: re-negotiate — CMAS picks the next available process\n\t\tProcessInterface.agreeandbook();\n\t\tProcessInterface.getXY();      // R3: get alternative\u0027s location at runtime\n\n\t\t// Move part from failed location to alternative process\n\t\t// R1: crane again only gets coordinates — still has no idea what happened\n\t\ttransport.position.x1:\u003dsavedX;\n\t\ttransport.position.y1:\u003dsavedY;\n\t\ttransport.position.x2:\u003dProcessInterface.x;\n\t\ttransport.position.y2:\u003dProcessInterface.y;\n\t\ttransport.agreeandbook();\n\t\ttransport.PickAndPlace();\n\t\ttransport._unbook();\n\n\t\t// Run the alternative\n\t\tthreadmessage(\u0027run alternative process\u0027);\n\t\tProcessInterface.run();        // R4: run the alternative\n\n\t\tif ProcessInterface.runFailed then begin\n\t\t\twriteln(\u0027All processes failed — part cannot complete\u0027);\n\t\t\t// R4: both failed — give up cleanly, no crash\n\t\t\tProcessInterface._unbook();\n\t\tend;\n\tend;\n\n\t// Deliver to sink (skipped automatically if both processes failed)\n\t// ── R1 + R3: deliver to sink — location fetched at runtime, crane gets coords\n\tif not ProcessInterface.runFailed then begin\n\t\tthreadmessage(\u0027ask a transporter to move to sink\u0027);\n\t\tsink.getXY();           // R3: sink position not hardcoded\n\t\ttransport.position.x1:\u003dProcessInterface.x;\n\t\ttransport.position.y1:\u003dProcessInterface.y;\n\t\ttransport.position.x2:\u003dsink.x;\n\t\ttransport.position.y2:\u003dsink.y;\n\t\ttransport.agreeandbook();\n\t\ttransport.PickAndPlace();         // R1: crane still only knows coordinates\n\t\ttransport._unbook();\n\n\t\tProcessInterface._unbook();\n\tend;\n// ── R5: this entire function executes because the LLM wrote\n    //        part_type\u003d2 → OrderIntake called deploybyname(\u0027Part2\u0027)\n    //        → this Part2 agent spawned and started running this plan.\n    //        The LLM never touched this code directly.\n       \n\n\tonRun:\u003dprocessplan.done;\nend."
              }
            ]
          ],
