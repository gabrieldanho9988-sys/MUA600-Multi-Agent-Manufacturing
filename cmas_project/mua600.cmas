                                  "LocalValue": "Program SkillPickAndPlace;\n\n$use \u0027crane_template\u0027\n\n// Make a static reference to our own interface for move\nstatic move:\u003d\u0027MoveInterfaceID\u0027 : interface;\n\nfunction onRun() : integer;\nbegin\t\n\tmove.agreeandbook();\n\n\tmove.x:\u003dinterface.position.x1;\n\tmove.y:\u003dinterface.position.y1;\t\n\tmove.pick();\n\n\tmove.y:\u003dSAFE_HEIGHT;\t\t\t\n\tmove.move();\n\t\n\tmove.x:\u003dinterface.position.x2;\n\tmove.y:\u003dinterface.position.y2;\t\t\n\tmove.place();\n\n\tmove.y:\u003dSAFE_HEIGHT;\t\t\t\n\tmove.move();\n\t\n\tmove._unbook();\t\n\t\n\t// Return value - running, done, failed or interrupted \n\tonRun:\u003dprocessplan.done;\nend."
                                }
                              ]
                            ],
                            "Relations": [
                              [
                                "Requirements"
                              ],
                              [
                                "Hazards"
                              ]
                            ],
                            "EntityType": "PROCESSPLAN",
                            "ProcessPlanType": "STRUCTUREDTEXT"
                          }
                        ]
                      ],
                      "EntityType": "INTERFACE"
                    },
