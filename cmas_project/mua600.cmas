                                  "LocalValue": "STRUCTUREDTEXT"
                                }
                              ],
                              [
                                "Cost",
                                {
                                  "Name": "Cost",
                                  "ClassName": "cmas.ontology.processplan.ProcessPlan",
                                  "Description": "The cost to execute the process plan, can be used for optimisation.",
                                  "CanInherit": true,
                                  "Override": true,
                                  "ReadOnly": false,
                                  "ParentID": "",
                                  "PropertyType": "[INHERITANCE]",
                                  "LocalValue": "0"
                                }
                              ],
                              [
                                "PostAction",
                                {
                                  "Name": "PostAction",
                                  "ClassName": "cmas.ontology.processplan.ProcessPlan",
                                  "Description": "An action to be execute after the process plan is done.",
                                  "CanInherit": true,
                                  "Override": true,
                                  "ReadOnly": false,
                                  "ParentID": "",
                                  "PropertyType": "[INHERITANCE]",
                                  "LocalValue": "NONE"
                                }
                              ],
                              [
                                "TargetType",
                                {
                                  "Name": "TargetType",
                                  "ClassName": "cmas.ontology.processplan.ProcessPlan",
                                  "Description": "A target type of the process plan.",
                                  "CanInherit": true,
                                  "Override": true,
                                  "ReadOnly": false,
                                  "ParentID": "",
                                  "PropertyType": "[STRINGEDIT, MODELLING]",
                                  "LocalValue": ""
                                }
                              ],
                              [
                                "Actions",
                                {
                                  "Name": "Actions",
                                  "ClassName": "cmas.ontology.processplan.ProcessPlanStructuredText",
                                  "Description": "Process plan actions",
                                  "CanInherit": true,
                                  "Override": true,
                                  "ReadOnly": false,
                                  "ParentID": "",
                                  "PropertyType": "[TEXTEDITOR]",
                                  "LocalValue": "Program SkilPick;\n\n$use \u0027crane_template\u0027\n\nvar state:\u003d0 : integer;\n\nprocedure changeState(newState:integer);\nbegin\n\tif newState\u003c\u003estate then begin\n\t\tif agent.debug then\n\t\t\twriteln(agent.name  + \u0027 will change to state for pick:\u0027, newState);\n\t\tstate:\u003dnewState;\n\tend;\nend.\n\nfunction onRun() : integer;\nbegin\n\tonRun:\u003dprocessplan.running;\n\t\n\tcase state of\n\t0: \n\t\tif agent.debug then\n\t\t\twriteln(\u0027will pick from x\u003d\u0027, interface.x, \u0027 y\u003d\u0027, interface.y);\n\t\t\t\n\t\tif isMowing() then error \u0027crane is mowing\u0027;\t\t\n\t\tchangeState(10);\n\n\t10:  // Check if we need to move to a safe height or not\n\t\tif agent.posY\u003e\u003dSAFE_HEIGHT then \n\t\t\tchangeState(40);\n\t\telse\n\t\t\tchangeState(20);\n\t\t\t\t\t\t\n\t20: // Move to a safe height\n\t\tagent.targetx:\u003dagent.posX;\t\n\t\tagent.targety:\u003dSAFE_HEIGHT;\n\t\tif isMowing( ) then changeState(30);\n\t\t\n\t30: // Check if we are safe\n\t\tif isAtTarget() then changeState(40);\n\n\t40:  // Move in x direction\n\t\tif isAtPosition(interface.x, agent.posY) then \n\t\t\tchangeState(70);\n\t\telse begin\t\n\t\t\tagent.targetx:\u003dinterface.x;\t\n\t\t\tagent.targety:\u003dagent.posY;\n\t\t\tchangeState(50);\n\t\tend;\n\t\n\t50:\n\t\tif isMowing( ) then changeState(60);\n\n\t60:  // Wait until move x is ready\n\t\tif isAtTarget() then changeState(70);\n\t\t\n\t70:  // Move y direction\n\t\tif isAtPosition(agent.posX, interface.y) then \n\t\t\tchangeState(100);\n\t\telse\n\t\t\tchangeState(80);\n\t\t\n\t80:\n\t\tagent.targetx:\u003dagent.posX;\n\t\tagent.targetY:\u003dinterface.y;\n\t\tif isMowing( ) then changeState(90);\n\t\t\n\t90:  // Wait until move y is ready\n\t\tif isAtTarget() then changeState(100);\n\t\t\n\t100:  // Activate vacuum\n\t\tagent.vacuum:\u003dtrue;\n\t\tchangeState(110);\n\t\n\t110:  // We are done\n\t\tonRun:\u003dprocessplan.done;\n\t\tchangeState(0);\n\telse:\n\t\terror \u0027wrong state: \u0027 + inttostring( state);\n\tend;\nend.\n"
                                }
                              ]
                            ],
