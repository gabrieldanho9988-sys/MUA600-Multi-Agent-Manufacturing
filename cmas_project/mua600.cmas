                              [
                                "Actions",
                                {
                                  "Name": "Actions",
                                  "ClassName": "cmas.ontology.processplan.ProcessPlanStructuredText",
                                  "Description": "Process plan actions",
                                  "CanInherit": true,
                                  "Override": true,
                                  "ReadOnly": false,
                                  "ParentID": "",
                                  "PropertyType": "[TEXTEDITOR]",
                                  "LocalValue": "Program SkillMove;\n\n$use \u0027crane_template\u0027\n\nvar state:\u003d0 : integer;\n\nprocedure changeState(newState:integer);\nbegin\n\tif newState\u003c\u003estate then begin\n\t\tif agent.debug then\n\t\t\twriteln(agent.name  + \u0027 will change to state for move:\u0027, newState);\n\t\t\t\n\t\tstate:\u003dnewState;\n\tend;\nend.\n\nfunction onRun() : integer;\nbegin\n\tonRun:\u003dprocessplan.running;\n\n\tcase state of\n\t0:\n\t\tif agent.debug then\t\n\t\t\twriteln(\u0027will move to x\u003d\u0027, interface.x, \u0027 y\u003d\u0027, interface.y);\n\t\t\t\n\t\tif isMowing() then error \u0027crane is mowing\u0027;\t\t\n\t\tchangeState(10);\n\n\t10:  // Check if we need to move\n\t\tif isAtPosition(interface.x, interface.y) then \n\t\t\tchangeState(40);\n\t\telse\n\t\t\tchangeState(20);\n\t20:\n\t\tagent.targetx:\u003dinterface.x;\t\n\t\tagent.targety:\u003dinterface.y;\n\t\tif isMowing( ) then changeState(30);\n\t30:\n\t\tif isAtTarget() then changeState(40);\n\t\n\t40:\n\t\tchangeState(0);\n\t\tonRun:\u003dprocessplan.done;\n\t\n\telse:\n\t\terror \u0027wrong state: \u0027 + inttostring( state);\n\tend;\nend."
                                }
                              ]
                            ],
                            "Relations": [
                              [
                                "Requirements"
                              ],
                              [
                                "Hazards"
                              ]
                            ],
                            "EntityType": "PROCESSPLAN",
                            "ProcessPlanType": "STRUCTUREDTEXT"
                          }
                        ]
