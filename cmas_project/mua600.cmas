                  [
                    "AutoDeploy",
                    {
                      "Name": "AutoDeploy",
                      "ClassName": "cmas.ontology.agents.Agent",
                      "Description": "If true the agent will be deployed at run",
                      "CanInherit": true,
                      "Override": true,
                      "ReadOnly": false,
                      "ParentID": "",
                      "PropertyType": "[INHERITANCE, HIDEBASIC]",
                      "LocalValue": "true"
                    }
                  ],
                  [
                    "Actions",
                    {
                      "Name": "Actions",
                      "ClassName": "cmas.ontology.agents.AgentAction",
                      "Description": "User defined actions",
                      "CanInherit": true,
                      "Override": true,
                      "ReadOnly": false,
                      "ParentID": "",
                      "PropertyType": "[TEXTEDITOR, MODELLING]",
                      "LocalValue": "program OrderIntake;\nvar latch1 :\u003d false : boolean;\nvar latch2 :\u003d false : boolean;\nvar p1 :\u003d 0 : integer;\nvar p2 :\u003d 0 : integer;\nprocedure running;\nbegin\n    p1 :\u003d agent.pending1;\n    if NOT agent.sensor1 then begin\n        latch1 :\u003d false;\n    end;\n    else if agent.sensor1 AND NOT latch1 AND (p1 \u003e 0) then\n    begin\n        writeln(\u0027OrderIntake: deploying Part1, pending after \u003d \u0027, p1 - 1);\n        if NOT deploybyname(\u0027Part1\u0027) then\n            error \u0027OrderIntake: deploybyname(Part1) returned false\u0027;\n        agent.pending1 :\u003d p1 - 1;\n        latch1 :\u003d true;\n    end;\n    p2 :\u003d agent.pending2;\n    if NOT agent.sensor2 then begin\n        latch2 :\u003d false;\n    end;\n    else if agent.sensor2 AND NOT latch2 AND (p2 \u003e 0) then\n    begin\n        writeln(\u0027OrderIntake: deploying Part2, pending after \u003d \u0027, p2 - 1);\n        if NOT deploybyname(\u0027Part2\u0027) then\n            error \u0027OrderIntake: deploybyname(Part2) returned false\u0027;\n        agent.pending2 :\u003d p2 - 1;\n        latch2 :\u003d true;\n    end;\n    sleep(100);\nend.\nprocedure onDeploy;\nbegin\n    latch1 :\u003d false;\n    latch2 :\u003d false;\nend."
                    }
                  ],
